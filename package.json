{
  "name": "journey-health-navigator",
  "private": true,
  "main": "index.js",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "expo start",
    "dev:ios": "bash ./scripts/ios-dev.sh",
    "build": "expo export",
    "lint": "expo lint",
    "typecheck": "tsc -p tsconfig.json",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "supabase:functions:deploy": "supabase functions deploy intake && supabase functions deploy marketing-researcher",
