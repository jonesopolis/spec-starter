    "supabase:functions:deploy:marketing": "supabase functions deploy marketing-researcher"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.7",
    "@expo/metro-runtime": "^6.1.2",
    "@journey/db": "workspace:*",
